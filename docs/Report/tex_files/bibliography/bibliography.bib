@book{ugwumba_programming_2026,
	title = {Programming {Paradigm} {Learning} {Curves}: {An} {Empirical} {Study} of {Developer} {Skill} {Acquisition} in {Functional}, {Object}-{Oriented}, and {Imperative} {Programming}},
	shorttitle = {Programming {Paradigm} {Learning} {Curves}},
	doi = {10.13140/RG.2.2.26177.01129},
	abstract = {This study examines how developers learn different programming paradigms by analyzing learning time, perceived difficulty, and experience related factors using an empirical cross sectional survey approach. Data were collected from students and professional developers through a structured questionnaire and analyzed using descriptive statistics, comparative analysis, and correlation based methods. The results show that time to competency varies across programming paradigms and is strongly influenced by abstraction level, prior programming experience, and learning resources. Paradigms requiring unfamiliar mental models and higher levels of abstraction are associated with longer learning durations and higher perceived difficulty. The findings align with existing research on programming education while extending it through comparative analysis across multiple paradigms within a single empirical framework. Despite limitations related to retrospective self reporting and cross sectional design, the study provides practical insights for learners and educators by highlighting the importance of paradigm aware learning sequences and instructional scaffolding in programming education.},
	author = {Ugwumba, Nnaemeka},
	month = jan,
	year = {2026},
	file = {Full Text PDF:C\:\\Users\\user\\Zotero\\storage\\A2GSBK8T\\Ugwumba - 2026 - Programming Paradigm Learning Curves An Empirical Study of Developer Skill Acquisition in Functiona.pdf:application/pdf},
